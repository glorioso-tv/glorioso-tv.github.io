<?xml version="1.0" encoding="UTF-8"?>
<window id="13002">
    <defaultcontrol>5000</defaultcontrol>
    <controls>
        <!-- SFONDO PRINCIPALE -->
        <control type="image" id="1000">
            <left>0</left>
            <top>0</top>
            <right>0</right>
