            <height>2</height>
            <texture colordiffuse="FFF7901E">white.png</texture>
        </control>

        <!-- LISTA DINAMICA PER I DATI DEGLI ADDON -->
        <control type="list" id="5000">
            <left>5%</left>
            <top>165</top>
            <right>5%</right>
            <bottom>100</bottom>
            <onup>9000</onup>
            <ondown>9000</ondown>
            <onleft>9000</onleft>
            <onright>9000</onright>
            <pagecontrol>-</pagecontrol>
            <scrolltime>200</scrolltime>
            <itemlayout height="35">
                <control type="label">
                    <left>0</left>
                    <top>0</top>
                    <width>15%</width>
                    <height>35</height>
                    <font>font13</font>
                    <textcolor>FFF7901E</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <info>ListItem.Property(percentage)</info>
                </control>
                <control type="label">
                    <left>15%</left>
                    <top>0</top>
                    <width>15%</width>
                    <height>35</height>
                    <font>font13</font>
                    <textcolor>white</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <info>ListItem.Property(size)</info>
                </control>
                <control type="label">
                    <left>35%</left>
                    <top>0</top>
                    <width>65%</width>
                    <height>35</height>
                    <font>font13</font>
                    <textcolor>white</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                    <info>ListItem.Label</info>
                </control>
            </itemlayout>
            <focusedlayout height="35">
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <right>0</right>
                    <height>35</height>
                    <texture colordiffuse="33FFFFFF">white.png</texture>
                </control>
                <control type="label">
                    <left>0</left>
                    <top>0</top>
                    <width>15%</width>
                    <height>35</height>
                    <font>font13</font>
                    <textcolor>FFF7901E</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <info>ListItem.Property(percentage)</info>
                </control>
                <control type="label">
                    <left>15%</left>
                    <top>0</top>
                    <width>15%</width>
                    <height>35</height>
                    <font>font13</font>
                    <textcolor>white</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <info>ListItem.Property(size)</info>
                </control>
                <control type="label">
                    <left>35%</left>
                    <top>0</top>
                    <width>65%</width>
