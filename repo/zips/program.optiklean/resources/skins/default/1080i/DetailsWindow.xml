        <!-- INTESTAZIONI COLONNE -->
        <control type="group" id="3000">
            <left>5%</left>
            <top>90</top>
            <right>5%</right>
            <height>40</height>
            
            <control type="label" id="10">
                <left>0</left>
                <top>0</top>
                <width>15%</width>
                <height>40</height>
                <label>30802</label>
                <font>font_title</font>
