                    <font>font13</font>
                    <textcolor>white</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                    <info>ListItem.Label</info>
                </control>
            </focusedlayout>
        </control>

        <!-- PULSANTE CHIUDI (X) -->
        <control type="button" id="9000">
            <right>20</right>
            <top>20</top>
            <width>60</width>
            <height>60</height>
            <texturefocus>close_focus.png</texturefocus>
            <texturenofocus>close.png</texturenofocus>
            <label></label>
            <onup>5000</onup>
            <ondown>5000</ondown>
            <onleft>5000</onleft>
            <onright>5000</onright>
        </control>
